# پیکربندی هوش مصنوعی ایرانی (مستقل از خارج ایران - بدون ریسک تحریم)
# با هر سرویس AI ایرانی که استاندارد OpenAI دارد کار می‌کند (آوال‌AI، لیارا، متیس و ...)
# اگر خالی بماند، سامانه خودکار از محتوای ثبت‌شده مدیر/کارشناسان استفاده می‌کند.
IRANIAN_AI_BASE_URL=""
IRANIAN_AI_API_KEY=""
IRANIAN_AI_MODEL="gpt-4o-mini"

APP_URL="https://codeyarplus.ir"

# دیتابیس (پیش‌فرض از db.json استفاده می‌شود و نیازی به MySQL نیست)
DB_HOST="localhost"
DB_USER="your_cpanel_db_username"
DB_PASS="your_secure_db_password"
DB_NAME="your_cpanel_db_name"

# پیامک (اختیاری)
# SMS_PROVIDER="farazsms"
# SMS_API_KEY="YOUR_IRAN_SMS_GATEWAY_API_KEY"
# SMS_LINE_NUMBER="3000505"

# درگاه پرداخت زرین‌پال
ZARINPAL_MERCHANT_ID="00000000-0000-0000-0000-000000000000"
ZARINPAL_SANDBOX="true"
