# ----------------------------------------------------------------------
# IRAN-SERVICE APACHE URL REWRITER FOR SECURE CPANEL DEPLOY
# ----------------------------------------------------------------------
# Forces routing of all /api/* requests to 'cpanel-api.php' for seamless sync.
# Place this .htaccess file inside the root public_html directory.
# ----------------------------------------------------------------------

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Route all API endpoints (Auth, Zarinpal, Plans, Repairs, state-sync, SMS, etc.) to api.php
  RewriteRule ^api/(.*)$ api.php?_url=api/$1 [QSA,L]

  # Regular SPA Client-Side Routing: if filename is not a real directory or file, pipe to index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . index.html [L]
</IfModule>
